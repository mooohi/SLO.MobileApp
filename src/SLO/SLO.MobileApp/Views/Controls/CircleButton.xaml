<?xml version="1.0" encoding="utf-8" ?>
<TemplatedView
    x:Class="SLO.MobileApp.Views.Controls.CircleButton"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:bases="clr-namespace:SLO.MobileApp.Views.Bases">

    <TemplatedView.ControlTemplate>

        <ControlTemplate>

            <bases:ButtonBase
                x:Name="ButtonBase"
                Background="{TemplateBinding Background}"
                BackgroundColor="{TemplateBinding ButtonColor}"
                Clicked="ButtonClicked"
                CornerRadius="{TemplateBinding Size}"
                FontAttributes="{TemplateBinding FontAttributes}"
                FontAutoScalingEnabled="True"
                FontSize="{TemplateBinding FontSize}"
                HeightRequest="{TemplateBinding BaseButtonDimensions}"
                Text="{TemplateBinding Text}"
                TextColor="{TemplateBinding TextColor}"
                WidthRequest="{TemplateBinding BaseButtonDimensions}" />

        </ControlTemplate>

    </TemplatedView.ControlTemplate>

</TemplatedView>
