<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SLO.MobileApp.Features.ShoppingLists.ShoppingListItem"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:labelBase="clr-namespace:SLO.MobileApp.Views.Bases"
    xmlns:models="clr-namespace:SLO.MobileApp.Core.Models.Foundations.ShoppingItems;assembly=SLO.MobileApp.Core"
    x:DataType="models:ShoppingItem">

    <Border
        Padding="10"
        Stroke="White"
        StrokeShape="RoundRectangle 10">

        <Grid
            ColumnDefinitions="*,*"
            RowDefinitions="*,*"
            RowSpacing="10">

            <labelBase:LabelBase
                Grid.Row="0"
                Grid.Column="0"
                HorizontalOptions="Start"
                Text="{Binding Name}" />

            <labelBase:LabelBase
                Grid.Row="0"
                Grid.Column="1"
                HorizontalOptions="End"
                Text="{Binding Quantity}" />

            <labelBase:LabelBase
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Text="{Binding Description}" />

        </Grid>
    </Border>
</ContentView>
