<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SLO.MobileApp.Features.ShoppingLists.Pages.ShoppingListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:android="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.AndroidSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:bases="clr-namespace:SLO.MobileApp.Views.Bases"
    xmlns:controls="clr-namespace:SLO.MobileApp.Views.Controls"
    xmlns:models="clr-namespace:SLO.MobileApp.Core.Models.Foundations.ShoppingItems;assembly=SLO.MobileApp.Core"
    xmlns:views="clr-namespace:SLO.MobileApp.Features.ShoppingLists.Views"
    x:DataType="views:ShoppingListItemView">

    <Grid RowDefinitions="*,Auto">

        <CollectionView
            x:Name="ItemsCollectionView"
            Grid.Row="0"
            Grid.RowSpan="2"
            Margin="10"
            ItemsSource="{Binding ShoppingItems}"
            ItemsUpdatingScrollMode="KeepScrollOffset">

            <CollectionView.EmptyView>
                <Grid
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill">

                    <bases:LabelBase
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        Text="Your cart is empty!"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />

                </Grid>

            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>

                <DataTemplate x:DataType="models:ShoppingItem">

                    <SwipeView android:SwipeView.SwipeTransitionMode="Drag">

                        <SwipeView.RightItems>

                            <SwipeItems>

                                <SwipeItem
                                    BackgroundColor="Red"
                                    Invoked="RemoveShoppingItemClicked"
                                    Text="Remove" />

                                <SwipeItem
                                    BackgroundColor="Orange"
                                    Invoked="EditShoppingItemClicked"
                                    Text="Edit" />

                            </SwipeItems>

                        </SwipeView.RightItems>

                        <views:ShoppingListItemView BindingContext="{Binding .}" />

                    </SwipeView>

                </DataTemplate>

            </CollectionView.ItemTemplate>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="5" Orientation="Vertical" />
            </CollectionView.ItemsLayout>

        </CollectionView>

        <Grid Grid.Row="1">

            <controls:CircleButton
                Margin="20"
                Clicked="AddNewItemClicked"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="End"
                Size="35"
                Text="+" />

        </Grid>

    </Grid>

</ContentPage>
