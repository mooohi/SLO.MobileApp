<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SLO.MobileApp.Features.ShoppingLists.Pages.AddShoppingListItemPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:bases="clr-namespace:SLO.MobileApp.Views.Bases"
    xmlns:local="clr-namespace:SLO.MobileApp.Features.ShoppingLists.Pages"
    x:DataType="local:AddShoppingListItemPage">

    <Grid
        Margin="10"
        ColumnDefinitions="*,*,*,*"
        ColumnSpacing="10"
        MaximumHeightRequest="160"
        RowDefinitions="*,*,*"
        RowSpacing="10">

        <Entry
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Text="{Binding Name, Mode=TwoWay}" />

        <Entry
            Grid.Row="0"
            Grid.Column="3"
            Text="{Binding Description, Mode=TwoWay}" />

        <Entry
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="4"
            Keyboard="Numeric"
            Text="{Binding Quantity, Mode=TwoWay}" />

        <bases:ButtonBase
            Grid.Row="2"
            Grid.Column="2"
            Text="Discard" />

        <bases:ButtonBase
            Grid.Row="2"
            Grid.Column="3"
            Clicked="SaveItem"
            Text="Save" />

    </Grid>

</ContentPage>