<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SLO.MobileApp.Features.ShoppingLists.ShoppingList"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:bases="clr-namespace:SLO.MobileApp.Views.Bases"
    xmlns:models="clr-namespace:SLO.MobileApp.Core.Models.Foundations.ShoppingItems;assembly=SLO.MobileApp.Core"
    xmlns:shoppinglists="clr-namespace:SLO.MobileApp.Features.ShoppingLists"
    x:DataType="shoppinglists:ShoppingList">

    <Grid RowDefinitions="*,Auto">

        <CollectionView
            x:Name="ItemsCollectionView"
            Grid.Row="0"
            Grid.RowSpan="2"
            Margin="10"
            ItemsSource="{Binding ShoppingItems}"
            ItemsUpdatingScrollMode="KeepScrollOffset">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ShoppingItem">
                    <shoppinglists:ShoppingListItem />
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="5" Orientation="Vertical" />
            </CollectionView.ItemsLayout>

        </CollectionView>

        <Grid Grid.Row="1">

            <bases:ButtonBase
                Margin="20"
                Clicked="AddNewItemButton"
                CornerRadius="30"
                FontAttributes="Bold"
                FontAutoScalingEnabled="True"
                FontSize="24"
                HeightRequest="60"
                HorizontalOptions="End"
                Text="+"
                WidthRequest="60" />

        </Grid>

    </Grid>

</ContentView>
