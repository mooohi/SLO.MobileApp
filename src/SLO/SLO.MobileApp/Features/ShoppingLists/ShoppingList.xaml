<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SLO.MobileApp.Features.ShoppingLists.ShoppingList"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:bases="clr-namespace:SLO.MobileApp.Views.Bases"
    xmlns:models="clr-namespace:SLO.MobileApp.Core.Models.Foundations.ShoppingItems;assembly=SLO.MobileApp.Core"
    xmlns:shoppinglists="clr-namespace:SLO.MobileApp.Features.ShoppingLists"
    x:DataType="shoppinglists:ShoppingList">

    <CollectionView ItemsSource="{Binding ShoppingItems}">

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:ShoppingItem">
                <shoppinglists:ShoppingListItem />
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentView>
